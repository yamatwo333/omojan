{
  "name": "omojan-prototype",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.888.0",
    "@aws-sdk/lib-dynamodb": "^3.888.0"
  },
  "scripts": {
    "build:lambda-bundle": "bash backend/lambda/api/build_bundle.sh",
    "start:mock-api": "node backend/mock_api/local_server.js",
    "start:lambda-api": "node backend/lambda/api/local_server.js",
    "test:mock-api": "node --test backend/mock_api/handler.test.js",
    "test:lambda-api": "node --test backend/lambda/api/handler.test.js",
    "test:e2e:phase": "playwright test tests/phase_live.spec.js --reporter=line",
    "test:e2e:app": "playwright test tests/omojan_app.spec.js --reporter=line",
    "test:e2e:admin": "playwright test tests/omojan_admin.spec.js --reporter=line"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
